 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# EPL Predictor — AWS SageMaker Deployment\n",
    "\n",
    "This notebook deploys the EPL Predictor as a SageMaker inference endpoint.\n",
    "It also sets up CloudWatch monitoring for prediction tracking.\n",
    "\n",
    "**Requirements:**\n",
    "- AWS Account with SageMaker access\n",
    "- ECR repository\n",
    "- Anthropic + Football Data API keys in Secrets Manager\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install deps\n",
    "!pip install boto3 sagemaker awscli -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import boto3\n",
    "import sagemaker\n",
    "import json\n",
    "import os\n",
    "\n",
    "# ─── Config ───────────────────────────────────────────────────────────────────\n",
    "REGION = 'us-east-1'  # Change to your region\n",
    "ACCOUNT_ID = boto3.client('sts').get_caller_identity()['Account']\n",
    "ECR_REPO = f'{ACCOUNT_ID}.dkr.ecr.{REGION}.amazonaws.com/epl-predictor'\n",
    "ROLE = sagemaker.get_execution_role()\n",
    "\n",
    "session = sagemaker.Session()\n",
    "print(f'Account: {ACCOUNT_ID}')\n",
    "print(f'Region: {REGION}')\n",
    "print(f'Role: {ROLE}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Step 1: Build & Push Docker image to ECR ─────────────────────────────────\n",
    "build_commands = f\"\"\"\n",
    "# Authenticate ECR\n",
    "aws ecr get-login-password --region {REGION} | \\\\\n",
    "  docker login --username AWS --password-stdin {ACCOUNT_ID}.dkr.ecr.{REGION}.amazonaws.com\n",
    "\n",
    "# Create ECR repo if not exists\n",
    "aws ecr create-repository --repository-name epl-predictor --region {REGION} 2>/dev/null || true\n",
    "\n",
    "# Build and push\n",
    "cd backend\n",
    "docker build -t epl-predictor:latest .\n",
    "docker tag epl-predictor:latest {ECR_REPO}:latest\n",
    "docker push {ECR_REPO}:latest\n",
    "\"\"\"\n",
    "print('Run these commands from your local machine or Cloud9:')\n",
    "print(build_commands)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Step 2: Store secrets in Parameter Store ────────────────────────────────\n",
    "ssm = boto3.client('ssm', region_name=REGION)\n",
    "\n",
    "def put_secret(name, value):\n",
    "    ssm.put_parameter(\n",
    "        Name=f'/epl-predictor/{name}',\n",
    "        Value=value,\n",
    "        Type='SecureString',\n",
    "        Overwrite=True\n",
    "    )\n",
    "    print(f'Stored: /epl-predictor/{name}')\n",
    "\n",
    "# Replace with actual keys\n",
    "# put_secret('ANTHROPIC_API_KEY', 'sk-ant-...')\n",
    "# put_secret('FOOTBALL_DATA_API_KEY', 'your-key')\n",
    "print('Uncomment and run with your actual API keys')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Step 3: Deploy to SageMaker Endpoint ────────────────────────────────────\n",
    "from sagemaker.model import Model\n",
    "\n",
    "model = Model(\n",
    "    image_uri=f'{ECR_REPO}:latest',\n",
    "    role=ROLE,\n",
    "    name='epl-predictor-model',\n",
    "    env={\n",
    "        'ENVIRONMENT': 'production',\n",
    "        # Keys loaded from Parameter Store at startup\n",
    "    }\n",
    ")\n",
    "\n",
    "predictor = model.deploy(\n",
    "    initial_instance_count=1,\n",
    "    instance_type='ml.t3.medium',  # Free tier eligible\n",
    "    endpoint_name='epl-predictor-endpoint',\n",
    "    wait=True,\n",
    ")\n",
    "\n",
    "print(f'Endpoint deployed: {predictor.endpoint_name}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Step 4: Test the endpoint ───────────────────────────────────────────────\n",
    "import json\n",
    "\n",
    "runtime = boto3.client('sagemaker-runtime', region_name=REGION)\n",
    "\n",
    "payload = json.dumps({\n",
    "    'home_team': 'Arsenal',\n",
    "    'away_team': 'Liverpool'\n",
    "})\n",
    "\n",
    "response = runtime.invoke_endpoint(\n",
    "    EndpointName='epl-predictor-endpoint',\n",
    "    ContentType='application/json',\n",
    "    Body=payload\n",
    ")\n",
    "\n",
    "result = json.loads(response['Body'].read())\n",
    "print(json.dumps(result, indent=2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Step 5: CloudWatch Monitoring Dashboard ─────────────────────────────────\n",
    "cloudwatch = boto3.client('cloudwatch', region_name=REGION)\n",
    "\n",
    "dashboard_body = {\n",
    "    'widgets': [\n",
    "        {\n",
    "            'type': 'metric',\n",
    "            'properties': {\n",
    "                'title': 'Prediction Latency (p95)',\n",
    "                'metrics': [['AWS/SageMaker', 'ModelLatency', 'EndpointName', 'epl-predictor-endpoint']],\n",
    "                'period': 300, 'stat': 'p95', 'view': 'timeSeries'\n",
    "            }\n",
    "        },\n",
    "        {\n",
    "            'type': 'metric',\n",
    "            'properties': {\n",
    "                'title': 'Invocations per Minute',\n",
    "                'metrics': [['AWS/SageMaker', 'Invocations', 'EndpointName', 'epl-predictor-endpoint']],\n",
    "                'period': 60, 'stat': 'Sum', 'view': 'timeSeries'\n",
    "            }\n",
    "        },\n",
    "        {\n",
    "            'type': 'metric',\n",
    "            'properties': {\n",
    "                'title': 'Error Rate',\n",
    "                'metrics': [['AWS/SageMaker', 'Invocation5XXErrors', 'EndpointName', 'epl-predictor-endpoint']],\n",
    "                'period': 60, 'stat': 'Sum', 'view': 'timeSeries'\n",
    "            }\n",
    "        }\n",
    "    ]\n",
    "}\n",
    "\n",
    "cloudwatch.put_dashboard(\n",
    "    DashboardName='EPL-Predictor-Monitoring',\n",
    "    DashboardBody=json.dumps(dashboard_body)\n",
    ")\n",
    "print('CloudWatch dashboard created: EPL-Predictor-Monitoring')"
   ]
  },
